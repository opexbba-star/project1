<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="index_coming_soon" inherit_id="website_event.index" name="Events Coming Soon">
        <xpath expr="//div[@id='o_wevent_index_main_col']//div[contains(@class, 'row')]" position="inside">
            <!-- Béjaïa Coming Soon -->
            <div class="col-md-6 col-lg-4 col-xl-3 mb-4">
                <article class="h-100 card border-0 shadow-sm opacity-75" style="filter: grayscale(0.8); pointer-events: none; user-select: none;">
                    <div class="position-relative h-100 d-flex flex-column">
                        <!-- Image Container -->
                        <div class="h-100 o_wevent_event_image_container position-relative overflow-hidden">
                            <img src="/ceo_homepage/static/src/img/event_bejaia_teaser.png" 
                                 class="card-img-top h-100 w-100" style="object-fit: cover; min-height: 250px;"/>
                            
                            <!-- Coming Soon Circle -->
                            <div class="position-absolute top-0 end-0 m-3 bg-white rounded-circle d-flex flex-column align-items-center justify-content-center shadow-sm" 
                                 style="width: 70px; height: 70px; border: 2px solid #fbb034;">
                                <span class="fw-bold text-dark small" style="font-size: 10px; line-height: 1;">BIENTÔT</span>
                                <span class="fw-bold text-dark" style="font-size: 18px;">---</span>
                            </div>
                        </div>
                        
                        <!-- Content -->
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title mt-2 mb-1 text-muted fw-bold">OPEX ROAD SHOW - BÉJAÏA</h5>
                            
                            <div class="mt-auto d-flex align-items-center text-muted small">
                                <i class="fa fa-map-marker me-2"/> Béjaïa, Algérie
                            </div>
                        </div>
                        
                        <!-- Footer -->
                        <div class="card-footer bg-white border-top-0 pt-0 pb-3">
                            <div class="d-flex align-items-center justify-content-between">
                                <span class="text-muted small italic">Date à confirmer</span>
                                <span class="badge rounded-pill bg-light text-muted border px-3 py-2">Prochainement</span>
                            </div>
                        </div>
                    </div>
                </article>
            </div>

            <!-- Ghardaïa Coming Soon -->
            <div class="col-md-6 col-lg-4 col-xl-3 mb-4">
                <article class="h-100 card border-0 shadow-sm opacity-75" style="filter: grayscale(0.8); pointer-events: none; user-select: none;">
                    <div class="position-relative h-100 d-flex flex-column">
                        <!-- Image Container -->
                        <div class="h-100 o_wevent_event_image_container position-relative overflow-hidden">
                            <img src="/ceo_homepage/static/src/img/event_ghardaia_teaser.png" 
                                 class="card-img-top h-100 w-100" style="object-fit: cover; min-height: 250px;"/>
                            
                            <!-- Coming Soon Circle -->
                            <div class="position-absolute top-0 end-0 m-3 bg-white rounded-circle d-flex flex-column align-items-center justify-content-center shadow-sm" 
                                 style="width: 70px; height: 70px; border: 2px solid #fbb034;">
                                <span class="fw-bold text-dark small" style="font-size: 10px; line-height: 1;">BIENTÔT</span>
                                <span class="fw-bold text-dark" style="font-size: 18px;">---</span>
                            </div>
                        </div>
                        
                        <!-- Content -->
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title mt-2 mb-1 text-muted fw-bold">OPEX ROAD SHOW - GHARDAÏA</h5>
                            
                            <div class="mt-auto d-flex align-items-center text-muted small">
                                <i class="fa fa-map-marker me-2"/> Ghardaïa, Algérie
                            </div>
                        </div>
                        
                        <!-- Footer -->
                        <div class="card-footer bg-white border-top-0 pt-0 pb-3">
                            <div class="d-flex align-items-center justify-content-between">
                                <span class="text-muted small italic">Date à confirmer</span>
                                <span class="badge rounded-pill bg-light text-muted border px-3 py-2">Prochainement</span>
                            </div>
                        </div>
                    </div>
                </article>
            </div>
        </xpath>
    </template>
</odoo>

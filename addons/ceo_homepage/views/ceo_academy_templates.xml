<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ══ Layout Shared Styles ══ -->
    <template id="ceo_academy_styles" inherit_id="website.layout" name="CEO Academy Styles">
        <xpath expr="//head" position="inside">
            <style type="text/css">
                .academy-hero {
                    background: linear-gradient(135deg, #1a1440 0%, #2d1b69 100%);
                    padding: 80px 0;
                    color: white;
                    text-align: center;
                }
                .academy-card {
                    border: none;
                    border-radius: 16px;
                    overflow: hidden;
                    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
                    transition: transform 0.3s ease, box-shadow 0.3s ease;
                    height: 100%;
                    background: white;
                }
                .academy-card:hover {
                    transform: translateY(-10px);
                    box-shadow: 0 20px 40px rgba(0,0,0,0.15);
                }
                .academy-card-img {
                    height: 200px;
                    background-size: cover;
                    background-position: center;
                    position: relative;
                }
                .academy-badge {
                    position: absolute;
                    top: 15px;
                    right: 15px;
                    background: #fbb034;
                    color: #1a1440;
                    padding: 4px 12px;
                    border-radius: 50px;
                    font-size: 12px;
                    font-weight: 700;
                    text-transform: uppercase;
                }
                .academy-card-body {
                    padding: 24px;
                }
                .academy-card-title {
                    font-size: 1.25rem;
                    font-weight: 800;
                    color: #1a1440;
                    margin-bottom: 12px;
                    line-height: 1.4;
                }
                .academy-meta {
                    display: flex;
                    align-items: center;
                    gap: 15px;
                    color: #64748b;
                    font-size: 14px;
                    margin-bottom: 20px;
                }
                .btn-academy {
                    background: #1a1440;
                    color: white;
                    border-radius: 8px;
                    padding: 10px 24px;
                    font-weight: 600;
                    transition: all 0.2s;
                    border: none;
                }
                .btn-academy:hover {
                    background: #fbb034;
                    color: #1a1440;
                }

                /* Detail Page Styles */
                .mc-header {
                    padding: 60px 0;
                    background: #f8fafc;
                    border-bottom: 1px solid #e2e8f0;
                }
                .mc-section-title {
                    font-weight: 800;
                    color: #1a1440;
                    margin-bottom: 25px;
                    position: relative;
                    padding-bottom: 10px;
                }
                .mc-section-title::after {
                    content: '';
                    position: absolute;
                    bottom: 0;
                    left: 0;
                    width: 40px;
                    height: 3px;
                    background: #fbb034;
                }
                .mc-box {
                    background: white;
                    border-radius: 16px;
                    padding: 30px;
                    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
                    margin-bottom: 30px;
                }
                .mc-label {
                    text-transform: uppercase;
                    font-size: 12px;
                    font-weight: 700;
                    letter-spacing: 1px;
                    color: #fbb034;
                    margin-bottom: 8px;
                }
            </style>
        </xpath>
    </template>

    <!-- ══ OpEx Academy Listing Page ══ -->
    <template id="ceo_academy_page" name="OpEx Academy">
        <t t-call="website.layout">
            <div id="wrap">
                <!-- Hero Section -->
                <section class="academy-hero">
                    <div class="container">
                        <h1 class="display-4 fw-bold mb-3">OpEx Academy</h1>
                        <p class="lead opacity-75 mx-auto" style="max-width: 700px;">
                            Découvrez nos masterclasses exclusives conçues pour transformer vos défis industriels 
                            en opportunités concrètes. Une immersion pratique dans l'Excellence Opérationnelle.
                        </p>
                    </div>
                </section>

                <!-- Introduction Text -->
                <section class="py-5 bg-white">
                    <div class="container">
                        <div class="row justify-content-center text-center">
                            <div class="col-lg-8">
                                <h2 class="fw-bold text-navy mb-4">Abonnement Masterclasses</h2>
                                <p class="text-muted fs-5">
                                    L'OpEx Academy propose un programme d'abonnement annuel donnant accès à des masterclasses 
                                    interactives, des ateliers de résolution de problèmes réels et un accompagnement par des experts 
                                    du Cluster. Apprenez à maîtriser le modèle HODA et les technologies de l'industrie 4.0.
                                </p>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Masterclasses Grid -->
                <section class="py-5 bg-light">
                    <div class="container">
                        <h3 class="fw-bold mb-5 text-center">Masterclasses à venir (Roadshow SBA)</h3>
                        <div class="row g-4">
                            <!-- Masterclass 1 -->
                            <div class="col-md-6 col-lg-4">
                                <div class="academy-card">
                                    <div class="academy-card-img" style="background-image: linear-gradient(to bottom right, #1a1440, #fbb034);">
                                        <span class="academy-badge">Atelier Pratique</span>
                                    </div>
                                    <div class="academy-card-body">
                                        <h4 class="academy-card-title">Problèmes industriels → Solutions innovantes</h4>
                                        <div class="academy-meta">
                                            <span>📍 Sidi Bel Abbès</span>
                                            <span>📅 Mai 2026</span>
                                        </div>
                                        <a href="/opex-academy/atelier-solutions-innovantes" class="btn btn-academy w-100 text-center d-block">Voir les détails</a>
                                    </div>
                                </div>
                            </div>

                            <!-- Masterclass 2 -->
                            <div class="col-md-6 col-lg-4">
                                <div class="academy-card">
                                    <div class="academy-card-img" style="background-image: linear-gradient(to bottom right, #2d1b69, #1a1440);">
                                        <span class="academy-badge">Stratégie &amp; Pitch</span>
                                    </div>
                                    <div class="academy-card-body">
                                        <h4 class="academy-card-title">Qualification du Pipe Startup et PME (OPEX)</h4>
                                        <div class="academy-meta">
                                            <span>📍 Sidi Bel Abbès</span>
                                            <span>📅 Mai 2026</span>
                                        </div>
                                        <a href="/opex-academy/atelier-qualification-opex" class="btn btn-academy w-100 text-center d-block">Voir les détails</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <!-- ══ Masterclass 1 Detail Page ══ -->
    <template id="ceo_masterclass_1" name="Masterclass Detail: Solutions Innovantes">
        <t t-call="website.layout">
            <div id="wrap">
                <section class="mc-header">
                    <div class="container">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="/opex-academy">OpEx Academy</a></li>
                                <li class="breadcrumb-item active">Atelier 1</li>
                            </ol>
                        </nav>
                        <h1 class="display-5 fw-bold text-navy mt-4">Atelier 1 : Problèmes industriels → Solutions innovantes → Projets activables</h1>
                        <div class="d-flex gap-4 mt-3 text-muted">
                            <div><strong>Lieu:</strong> Sidi Bel Abbès</div>
                            <div><strong>Type:</strong> Workshop Collaboratif</div>
                        </div>
                    </div>
                </section>

                <section class="py-5">
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-8">
                                <h3 class="mc-section-title">Description du Workshop</h3>
                                <p class="fs-5 text-muted mb-5">
                                    Cet atelier vise à créer un pont direct entre les besoins réels de l'industrie et les capacités 
                                    d'innovation locales. Nous transformons des problèmes concrets en fiches projets structurées et prêtes à être activées.
                                </p>

                                <div class="row g-4 mb-5">
                                    <div class="col-md-6">
                                        <div class="mc-box border-start border-4 border-primary">
                                            <div class="mc-label">Inputs</div>
                                            <p class="mb-0 fw-bold">Problèmes réels (industries / PME)</p>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="mc-box border-start border-4 border-warning">
                                            <div class="mc-label">Outputs</div>
                                            <ul class="ps-3 mb-0">
                                                <li>1 problème = 1 à 3 solutions</li>
                                                <li>Pré-projet structuré (fiche rapide)</li>
                                                <li>Potentiel porteurs de projets</li>
                                                <li>Intégration PFE dans Projet réel</li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>

                                <h3 class="mc-section-title">Méthodologie de Travail</h3>
                                <div class="mc-box">
                                    <p class="fs-6">
                                        Le travail se fait en <strong>groupes mixtes</strong> réunissant tous les acteurs de l'écosystème :
                                    </p>
                                    <div class="d-flex flex-wrap gap-2 mt-3">
                                        <span class="badge bg-light text-navy border p-2">Étudiants (M1)</span>
                                        <span class="badge bg-light text-navy border p-2">Experts (CEO)</span>
                                        <span class="badge bg-light text-navy border p-2">Encadrants</span>
                                        <span class="badge bg-light text-navy border p-2">Entreprises</span>
                                    </div>
                                </div>

                                <!-- CTA Section -->
                                <div class="bg-navy text-white p-5 rounded-4 mt-5 text-center shadow-lg">
                                    <h2 class="fw-bold mb-3">Prêt à participer ?</h2>
                                    <p class="mb-4 opacity-75">Inscrivez-vous dès maintenant pour réserver votre place à cet atelier exclusif.</p>
                                    <a href="https://ceo.deltalog.dz/survey/start/77e7b29d-7c33-43c7-965b-47a3e5d55361" target="_blank" class="btn btn-warning btn-lg px-5 fw-bold text-navy">S'inscrire via Survey</a>
                                </div>
                            </div>

                            <div class="col-lg-4">
                                <div class="mc-box sticky-top" style="top: 100px;">
                                    <h4 class="fw-bold mb-4">Infos Clés</h4>
                                    <ul class="list-unstyled d-flex flex-column gap-3">
                                        <li>📅 <strong>Date:</strong> Mai 2026</li>
                                        <li>🕒 <strong>Durée:</strong> 1 Journée</li>
                                        <li>🎯 <strong>Cible:</strong> Industries, PME, Étudiants</li>
                                        <li>💎 <strong>Avantages:</strong> Networking, Résolution de problèmes, Talent hunting</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <!-- ══ Masterclass 2 Detail Page ══ -->
    <template id="ceo_masterclass_2" name="Masterclass Detail: Qualification Pipe">
        <t t-call="website.layout">
            <div id="wrap">
                <section class="mc-header">
                    <div class="container">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="/opex-academy">OpEx Academy</a></li>
                                <li class="breadcrumb-item active">Atelier 2</li>
                            </ol>
                        </nav>
                        <h1 class="display-5 fw-bold text-navy mt-4">Atelier 2 : Qualification du Pipe Startup et PME existant (OPEX)</h1>
                        <div class="d-flex gap-4 mt-3 text-muted">
                            <div><strong>Lieu:</strong> Sidi Bel Abbès</div>
                            <div><strong>Type:</strong> Matching &amp; Pitch</div>
                        </div>
                    </div>
                </section>

                <section class="py-5">
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-8">
                                <h3 class="mc-section-title">Objectifs du Workshop</h3>
                                <p class="fs-5 text-muted mb-5">
                                    Cet atelier est dédié aux startups et PME opérant dans le domaine de l'Excellence Opérationnelle. 
                                    L'objectif est de valider les solutions technologiques face aux besoins réels et d'accélérer le matching business.
                                </p>

                                <div class="mc-box border-start border-4 border-primary mb-5">
                                    <div class="mc-label">Inputs : Domaines ciblés</div>
                                    <p class="mb-0">PME et Startups existantes proche des domaines OpEx :</p>
                                    <ul class="mt-2">
                                        <li>Optimisation processus</li>
                                        <li>Digitalisation (ERP, IoT, Data)</li>
                                        <li>Maintenance &amp; performance</li>
                                        <li>IA appliquée</li>
                                    </ul>
                                </div>

                                <h3 class="mc-section-title">Processus de Travail</h3>
                                <div class="row g-4 mb-5">
                                    <div class="col-md-4">
                                        <div class="mc-box h-100 text-center">
                                            <div class="display-6 fw-bold text-navy mb-2">01</div>
                                            <strong>Pitch Solutions</strong>
                                            <p class="small mt-2">Présentation des solutions par les startups et PME.</p>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mc-box h-100 text-center">
                                            <div class="display-6 fw-bold text-navy mb-2">02</div>
                                            <strong>Matching</strong>
                                            <p class="small mt-2">Identification du lien Solution → Besoin PME.</p>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="mc-box h-100 text-center">
                                            <div class="display-6 fw-bold text-navy mb-2">03</div>
                                            <strong>Réorientation</strong>
                                            <p class="small mt-2">Redéfinition ou repositionnement intelligent du projet.</p>
                                        </div>
                                    </div>
                                </div>

                                <div class="mc-box border-start border-4 border-warning">
                                    <div class="mc-label">Output Final</div>
                                    <p class="mb-0 fw-bold">Réorientation intelligente : Redéfinir le problème, Adapter la solution, ou repositionner le projet pour un impact maximal.</p>
                                </div>

                                <!-- CTA Section -->
                                <div class="bg-navy text-white p-5 rounded-4 mt-5 text-center shadow-lg">
                                    <h2 class="fw-bold mb-3">Boostez votre projet</h2>
                                    <p class="mb-4 opacity-75">Soumettez votre solution et participez à la session de matching stratégique.</p>
                                    <a href="https://ceo.deltalog.dz/survey/start/6a6d721d-b294-402b-9a67-5c692e3364ad" target="_blank" class="btn btn-warning btn-lg px-5 fw-bold text-navy">S'inscrire via Survey</a>
                                </div>
                            </div>

                            <div class="col-lg-4">
                                <div class="mc-box sticky-top" style="top: 100px;">
                                    <h4 class="fw-bold mb-4">Infos Clés</h4>
                                    <ul class="list-unstyled d-flex flex-column gap-3">
                                        <li>📅 <strong>Date:</strong> Mai 2026</li>
                                        <li>🕒 <strong>Durée:</strong> 1/2 Journée</li>
                                        <li>🎯 <strong>Cible:</strong> Startups, PME Technos, Entreprises</li>
                                        <li>💎 <strong>Avantages:</strong> Feedback expert, Visibilité, Opportunités Business</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>

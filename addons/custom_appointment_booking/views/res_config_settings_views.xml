<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_calendar_custom" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.calendar.custom</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='sync_google_calendar_setting']" position="after">
                <block title="Appointment Working Hours" name="appointment_working_hours">
                    <field name="allowed_start_hour"/>
                    <field name="allowed_end_hour"/>
                </block>
            </xpath>
        </field>
    </record>
</odoo>

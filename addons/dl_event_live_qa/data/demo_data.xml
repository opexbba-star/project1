<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Données de démo — chargées uniquement quand Odoo est démarré avec
            les données de démo activées ET que les données de démo de
            website_event_track sont présentes (référence event_track1).
        -->

        <!-- Active le Q&A sur une session de démo existante -->
        <record id="website_event_track.event_track1" model="event.track">
            <field name="qa_enabled">True</field>
            <field name="qa_state">active</field>
            <field name="qa_access_token">demo-qa-track-1-token</field>
        </record>

        <record id="demo_qa_question_1" model="event.qa.question">
            <field name="track_id" ref="website_event_track.event_track1"/>
            <field name="author_name">Alice</field>
            <field name="question_text">Un enregistrement sera-t-il disponible après l'évènement ?</field>
            <field name="state">approved</field>
            <field name="vote_count">12</field>
        </record>

        <record id="demo_qa_question_2" model="event.qa.question">
            <field name="track_id" ref="website_event_track.event_track1"/>
            <field name="author_name">Bob</field>
            <field name="question_text">Comment accéder aux slides présentées pendant la session ?</field>
            <field name="state">approved</field>
            <field name="vote_count">8</field>
        </record>

        <record id="demo_qa_question_3" model="event.qa.question">
            <field name="track_id" ref="website_event_track.event_track1"/>
            <field name="author_name">Anonyme</field>
            <field name="question_text">Quelle est la feuille de route pour les 6 prochains mois ?</field>
            <field name="state">pending</field>
            <field name="vote_count">0</field>
        </record>

        <record id="demo_qa_question_4" model="event.qa.question">
            <field name="track_id" ref="website_event_track.event_track1"/>
            <field name="author_name">Charlie</field>
            <field name="question_text">Pouvez-vous détailler l'intégration avec les outils tiers ?</field>
            <field name="state">answered</field>
            <field name="vote_count">5</field>
        </record>

    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Une seule entrée "Q&A en direct" sous le menu principal Évènements
        qui liste toutes les questions de toutes les sessions. Les contrôles
        Q&A vivent désormais directement sur chaque fiche event.track
        (onglet Q&A en direct + smart button).
    -->

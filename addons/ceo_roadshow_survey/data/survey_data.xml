        <record id="survey_sba_section_3" model="survey.question">
            <field name="title">Intérêts pour les sujets présentés</field>
            <field name="survey_id" ref="survey_sba_2026"/>
            <field name="is_page" eval="True"/>
            <field name="sequence">30</field>
        </record>

        <record id="q_matrix_interest" model="survey.question">
            <field name="title">Notez votre niveau d'intérêt pour les thèmes suivants :</field>
            <field name="survey_id" ref="survey_sba_2026"/>
            <field name="question_type">matrix</field>
            <field name="matrix_subtype">simple</field>
            <field name="sequence">31</field>
        </record>
        <!-- Colonnes Matrix -->
        <record id="col_5" model="survey.question.answer"><field name="matrix_question_id" ref="q_matrix_interest"/><field name="value">5 (Fort)</field><field name="sequence">1</field></record>
        <record id="col_3" model="survey.question.answer"><field name="matrix_question_id" ref="q_matrix_interest"/><field name="value">3 (Moyen)</field><field name="sequence">2</field></record>
        <record id="col_1" model="survey.question.answer"><field name="matrix_question_id" ref="q_matrix_interest"/><field name="value">1 (Faible)</field><field name="sequence">3</field></record>
        <!-- Lignes Matrix (Thèmes) -->
        <record id="row_1" model="survey.question.answer"><field name="question_id" ref="q_matrix_interest"/><field name="value">Conférence 1 : Management &amp; IA</field></record>
        <record id="row_2" model="survey.question.answer"><field name="question_id" ref="q_matrix_interest"/><field name="value">Conférence 2 : Ecosystème Innovation</field></record>
        <record id="row_3" model="survey.question.answer"><field name="question_id" ref="q_matrix_interest"/><field name="value">Débats (Normes, Emploi, Décision)</field></record>
        <record id="row_4" model="survey.question.answer"><field name="question_id" ref="q_matrix_interest"/><field name="value">Ateliers Design Thinking / Startup</field></record>

        <record id="q_attentes" model="survey.question">
            <field name="title">Qu’attendez-vous de votre participation à cet événement ?</field>
            <field name="survey_id" ref="survey_sba_2026"/>
            <field name="question_type">text_box</field>
            <field name="sequence">32</field>
        </record>

        <record id="q_sponsor_interest" model="survey.question">
            <field name="title">Êtes-vous intéressé par une offre de sponsoring ?</field>
            <field name="survey_id" ref="survey_sba_2026"/>
            <field name="question_type">simple_choice</field>
            <field name="constr_mandatory" eval="True"/>
            <field name="sequence">33</field>
        </record>
        <record id="ans_sp_y" model="survey.question.answer"><field name="question_id" ref="q_sponsor_interest"/><field name="value">Oui</field></record>
        <record id="ans_sp_n" model="survey.question.answer"><field name="question_id" ref="q_sponsor_interest"/><field name="value">Non</field></record>
        <record id="ans_sp_d" model="survey.question.answer"><field name="question_id" ref="q_sponsor_interest"/><field name="value">A discuter</field></record>

        <!-- Section 4: Restez connectés -->
        <record id="survey_sba_section_4" model="survey.question">
            <field name="title">Restez connectés</field>
            <field name="survey_id" ref="survey_sba_2026"/>
            <field name="is_page" eval="True"/>
            <field name="sequence">40</field>
        </record>

        <record id="q_rappel" model="survey.question">
            <field name="title">Souhaitez-vous recevoir un rappel par e-mail ou WhatsApp avant l’événement ?</field>
            <field name="survey_id" ref="survey_sba_2026"/>
            <field name="question_type">simple_choice</field>
            <field name="constr_mandatory" eval="True"/>

<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_slide_channel_form_inherit_points" model="ir.ui.view">
        <field name="name">slide.channel.form.inherit.points</field>
        <field name="model">slide.channel</field>
        <field name="inherit_id" ref="website_slides.view_slide_channel_form"/>
        <field name="arch" type="xml">

            <!-- Insert REQUIRED POINTS inside: Options → Access Rights group -->
            <xpath expr="//page[@name='options']//group[@name='access_rights']" position="inside">
                <field name="x_points_cost"/>
            </xpath>

        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="portal_my_home_points" inherit_id="portal.portal_my_home">
        <xpath expr="//div[@id='portal_common_category']" position="before">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/loyalty/static/src/img/ewallet.svg'"/>
                <t t-set="title">Mes Points</t>
                <t t-set="text">Vous avez <t t-esc="request.env.user.x_points"/> points de fidélité 🎯</t>
                <t t-set="url" t-value="'/my/points'"/>
                <t t-set="config_card" t-value="True"/>
            </t>
        </xpath>
    </template>

    <template id="portal_my_points" name="Mes Points de Fidélité">
        <t t-call="portal.portal_layout">
            <t t-set="page_name">my_points</t>
            <t t-set="additional_title">Mes Points</t>

            <div class="o_portal_my_points w-md-75 w-lg-50 pb-5">
                <h3>Vos Points de Fidélité 🎯</h3>
                <p>Vous disposez actuellement de :
                    <strong><t t-esc="points"/></strong> points.
                </p>

                <p>Vous avez déjà demandé :
                    <strong><t t-esc="requested_points"/></strong> points.
                </p>


                <!-- BANDEAU AFFICHÉ UNIQUEMENT SI L'UTILISATEUR N'EST PAS ADHÉRENT -->
                <t t-if="not request.env.user.x_is_adherent">
                    <div class="alert alert-info mt-4 p-3" role="alert">
                        <h5 class="mb-2">Devenez Adhérent 💎</h5>
                        <p class="mb-3">
                            Rejoignez-nous en tant qu'adhérent pour explorer et utiliser pleinement vos points et accéder à notre gamme complète de services.
                        </p>
                        <a href="/contactus" class="btn btn-primary">
                            Nous contacter pour adhérer
                        </a>
                    </div>
                </t>


                <!-- FORMULAIRE DE DEMANDE AFFICHÉ UNIQUEMENT POUR LES ADHÉRENTS -->
                <form action="/my/points/request" method="post" class="mt-4">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <t t-if="request.env.user.x_is_adherent">
                        <label for="req_points" class="form-label">Demander des points supplémentaires :</label>
                        <input type="number" id="req_points" name="request_points"
                            min="1" class="form-control w-50 mb-3"/>

                        <button class="btn btn-primary">Confirmer la demande</button>
                    </t>
                </form>
            </div>
        </t>
    </template>
</odoo>
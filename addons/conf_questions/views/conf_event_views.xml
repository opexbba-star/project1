<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List view -->
    <record id="view_conf_event_list" model="ir.ui.view">
        <field name="name">conf.event.list</field>
        <field name="model">conf.event</field>
        <field name="arch" type="xml">
            <list string="Événements" decoration-success="status == 'live'"
                  decoration-muted="status == 'closed'">
                <field name="name"/>
                <field name="date"/>
                <field name="status"
                       widget="badge"
                       decoration-success="status == 'live'"
                       decoration-info="status == 'draft'"
                       decoration-danger="status == 'closed'"/>
                <field name="question_count" string="Questions"/>
                <field name="pending_count" string="En attente"/>
                <field name="slug" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_conf_event_form" model="ir.ui.view">
        <field name="name">conf.event.form</field>
        <field name="model">conf.event</field>
        <field name="arch" type="xml">
            <form string="Événement">
                <header>
                    <button name="action_set_live" string="Mettre En Live"
                            type="object" class="btn-primary"
                            invisible="status == 'live'"/>
                    <button name="action_set_draft" string="Repasser en Planifié"
                            type="object"
                            invisible="status != 'live'"/>
                    <button name="action_set_closed" string="Clôturer"
                            type="object" class="btn-danger"
                            invisible="status == 'closed'"/>
                    <button name="action_open_dashboard" string="🖥 Tableau de Bord"
                            type="object" class="btn-secondary"/>
                    <button name="action_open_public_link" string="🔗 Lien Public"
                            type="object" class="btn-secondary"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="draft,live,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nom de l'événement"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="slug" readonly="1"/>
                        </group>
                        <group>
                            <field name="question_count" string="Total questions"/>
                            <field name="pending_count" string="En attente"/>
                            <field name="read_count" string="Traitées"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Description de l'événement (optionnel)"/>
                    <notebook>
                        <page string="Questions" name="questions">
                            <field name="question_ids" readonly="1">
                                <list>
                                    <field name="submitted_at" string="Heure"/>
                                    <field name="submitter_name" string="Prénom"/>
                                    <field name="question_text" string="Question"/>
                                    <field name="state" widget="badge"
                                           decoration-warning="state == 'pending'"
                                           decoration-success="state == 'read'"
                                           decoration-info="state == 'skipped'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Kanban view -->
    <record id="view_conf_event_kanban" model="ir.ui.view">
        <field name="name">conf.event.kanban</field>
        <field name="model">conf.event</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column" default_order="date desc">
                <field name="name"/>
                <field name="description"/>
                <field name="date"/>
                <field name="status"/>
                <field name="question_count"/>
                <field name="pending_count"/>
                <field name="slug"/>
                <field name="id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <strong class="fs-5 text-primary">
                                    <field name="name"/>
                                </strong>
                                <span t-if="record.status.raw_value == 'live'"
                                      class="badge bg-success">EN LIVE</span>
                                <span t-elif="record.status.raw_value == 'draft'"
                                      class="badge bg-secondary">PLANIFIÉ</span>
                                <span t-else=""
                                      class="badge bg-dark">CLÔTURÉ</span>
                            </div>
                            <p class="text-muted small mb-3">
                                <t t-if="record.description.value">
                                    <field name="description"/>
                                </t>
                                <t t-else="">Aucune description</t>
                            </p>
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="text-uppercase small text-muted">Date</span><br/>
                                    <strong><field name="date"/></strong>
                                </div>
                                <span class="small text-muted">
                                    <field name="question_count"/> question(s)
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_conf_event_search" model="ir.ui.view">
        <field name="name">conf.event.search</field>
        <field name="model">conf.event</field>
        <field name="arch" type="xml">
            <search string="Rechercher des événements">
                <field name="name"/>
                <filter string="En Live" name="live" domain="[('status','=','live')]"/>
                <filter string="Planifiés" name="draft" domain="[('status','=','draft')]"/>
                <filter string="Clôturés" name="closed" domain="[('status','=','closed')]"/>
                <separator/>
                <filter string="En cours" name="ongoing"
                        domain="[('status','in',['live','draft'])]"/>
                <group expand="0" string="Grouper par">
                    <filter string="Statut" name="group_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_conf_event" model="ir.actions.act_window">
        <field name="name">Événements</field>
        <field name="res_model">conf.event</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_conf_event_search"/>
        <field name="context">{'search_default_ongoing': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créez votre premier événement !
            </p>
            <p>
                Gérez les questions de vos participants en temps réel.
            </p>
        </field>
    </record>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="template_admin_events" name="Admin Events Overview">
        <html lang="fr">
            <head>
                <meta charset="UTF-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
                <title>Événements — Conférence Questions</title>
                <link rel="stylesheet" href="/conf_questions/static/src/css/style.css"/>
            </head>
            <body class="conf-events-page">

                <!-- Page header -->
                <div class="events-header">
                    <h1>Événements</h1>
                    <button class="btn-new-event" onclick="openNewEventModal()">
                        + Nouvel Événement
                    </button>
                </div>

                <!-- Ongoing events -->
                <div class="events-section">
                    <div class="events-section-title">
                        🚀 Événements en cours
                        <span class="events-count-badge">
                            <t t-out="len(ongoing_events)"/>
                        </span>
                    </div>
                    <t t-if="ongoing_events">
                        <div class="events-grid">
                            <t t-foreach="ongoing_events" t-as="event">
                                <div class="event-card">
                                    <div class="event-card-header">
                                        <span class="event-name" t-out="event.name"/>
                                        <div style="display:flex;gap:8px;align-items:center">
                                            <span t-if="event.status == 'live'"
                                                  class="status-badge badge-live">EN LIVE</span>
                                            <span t-elif="event.status == 'draft'"
                                                  class="status-badge badge-draft">PLANIFIÉ</span>
                                            <button class="btn-delete-event"
                                                    t-attf-onclick="deleteEvent(#{event.id})"
                                                    title="Supprimer cet événement">🗑</button>
                                        </div>
                                    </div>
                                    <div class="event-description">
                                        <t t-if="event.description" t-out="event.description"/>
                                        <t t-else="">Aucune description</t>
                                    </div>
                                    <div class="event-card-footer">
                                        <div>
                                            <div class="event-date">DATE</div>
                                            <div class="event-date">
                                                <strong>
                                                    <t t-if="event.date"
                                                       t-out="event.date.strftime('%m/%d/%Y')"/>
                                                    <t t-else="">—</t>
                                                </strong>
                                            </div>
                                        </div>
                                        <span class="event-question-count">
                                            <t t-out="event.question_count"/> question<t t-if="event.question_count != 1">s</t>
                                        </span>
                                        <a class="btn-manage"
                                           t-attf-href="/conf/dashboard/#{event.id}">
                                            Gérer →
                                        </a>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                    <t t-else="">
                        <p class="no-questions">Aucun événement en cours</p>
                    </t>
                </div>

                <!-- History events -->
                <t t-if="past_events">
                    <div class="events-section">
                        <div class="events-section-title">
                            📁 Historique
                            <span class="events-count-badge">
                                <t t-out="len(past_events)"/>
                            </span>
                        </div>
                        <div class="events-grid">
                            <t t-foreach="past_events" t-as="event">
                                <div class="event-card event-card-closed">
                                    <div class="event-card-header">
                                        <span class="event-name event-name-muted"
                                              t-out="event.name"/>
                                        <div style="display:flex;gap:8px;align-items:center">
                                            <span class="status-badge badge-closed">CLÔTURÉ</span>
                                            <button class="btn-delete-event"
                                                    t-attf-onclick="deleteEvent(#{event.id})"
                                                    title="Supprimer cet événement">🗑</button>
                                        </div>
                                    </div>
                                    <div class="event-description">
                                        <t t-if="event.description" t-out="event.description"/>
                                        <t t-else="">Aucune description</t>
                                    </div>
                                    <div style="margin-top:12px;font-size:0.85rem;color:#888;display:flex;gap:16px">
                                        <span>
                                            <t t-if="event.date"
                                               t-out="event.date.strftime('%m/%d/%Y')"/>
                                            <t t-else="">—</t>
                                        </span>
                                        <span>
                                            <t t-out="event.question_count"/> question<t t-if="event.question_count != 1">s</t>
                                        </span>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>

                <!-- New Event Modal -->
                <div id="new-event-modal" class="modal-overlay" style="display:none">
                    <div class="modal-box">
                        <div class="modal-title">Nouvel Événement</div>
                        <form method="post" action="/conf/events/create">
                            <input type="hidden" name="csrf_token"
                                   t-att-value="request.csrf_token()"/>
                            <div class="form-group">
                                <label for="event_name">
                                    Nom de l'événement <span class="required">*</span>
                                </label>
                                <input type="text" id="event_name" name="event_name"
                                       placeholder="ex: Conférence SBA 2026"
                                       required="required"/>
                            </div>
                            <div class="form-group">
                                <label for="event_description">Description</label>
                                <textarea id="event_description" name="event_description"
                                          rows="3"
                                          placeholder="Description (optionnel)"/>
                            </div>
                            <div class="form-group">
                                <label for="event_date">Date</label>
                                <input type="date" id="event_date" name="event_date"/>
                            </div>
                            <div class="form-group">
                                <label for="event_status">Statut initial</label>
                                <select id="event_status" name="event_status">
                                    <option value="draft">Planifié</option>
                                    <option value="live">En Live</option>
                                </select>
                            </div>
                            <div class="modal-actions">
                                <button type="button" class="btn-cancel"
                                        onclick="closeNewEventModal()">
                                    Annuler
                                </button>
                                <button type="submit" class="btn-create">
                                    Créer l'événement
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <script src="/conf_questions/static/src/js/events.js"/>
            </body>
        </html>
    </template>
</odoo>

<odoo>
    <record id="view_ceo_membership_plan_tree" model="ir.ui.view">
        <field name="name">ceo.membership.plan.list</field>
        <field name="model">ceo.membership.plan</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="code"/>
                <field name="target_profile"/>
                <field name="annual_fee"/>
                <field name="duration_months"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_ceo_membership_plan_form" model="ir.ui.view">
        <field name="name">ceo.membership.plan.form</field>
        <field name="model">ceo.membership.plan</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group><field name="name"/><field name="code"/><field name="sequence"/><field name="active"/></group>
                        <group><field name="target_profile"/><field name="duration_months"/><field name="annual_fee"/><field name="currency_id"/></group>
                    </group>
                    <group string="Avantages inclus">
                        <field name="allow_portal_access"/><field name="include_directory_visibility"/><field name="include_diagnostic"/><field name="include_logo_visibility"/><field name="include_copil"/>
                    </group>
                    <notebook><page string="Description"><field name="description"/><field name="benefits"/></page></notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_ceo_membership_plan" model="ir.actions.act_window">
        <field name="name">Formules d’adhésion</field><field name="res_model">ceo.membership.plan</field><field name="view_mode">list,form</field>
    </record>
</odoo>
